{
  "name": "sylphx-numpy-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "bench:python-parity": "bun run bench/python-parity/compare.ts",
    "bench:python-parity:enforce": "bun run bench/python-parity/compare.ts --enforce",
    "bench:python-parity:repeatability": "bun run bench/python-parity/repeatability.ts",
    "bench:python-parity:report": "bun run bench/python-parity/report.ts",
    "bench:python-parity:report:check": "bun run bench/python-parity/report.ts --check",
    "bench:native-dispatch": "bun run bench/python-parity/native_dispatch_probe.ts",
    "release:preflight": "bun run scripts/release-preflight.ts",
    "release:readback": "bun run scripts/verify-npm-readback.ts",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "echo \"Direct changeset publish is unsafe for workspace packages; use the Sylphx release workflow.\" && exit 1",
    "test:project-control": "node --test test/project-control.node-test.mjs",
    "groundatlas:fleet": "npm exec --yes --package groundatlas@0.1.2 -- ga fleet . --out .groundatlas-pilot --require-atlas --strict --json"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.10",
    "mitata": "^1.0.34",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "bun@1.3.14"
}
