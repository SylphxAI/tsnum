{
  "name": "@sylphx/numpy",
  "version": "0.0.0",
  "description": "NumPy-compatible TypeScript numerical engine with native, BLAS, and WASM backend paths",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ops": {
      "import": "./dist/ops/index.js",
      "types": "./dist/ops/index.d.ts"
    },
    "./fn": {
      "import": "./dist/functional.js",
      "types": "./dist/functional.d.ts"
    },
    "./linalg": {
      "import": "./dist/linalg/index.js",
      "types": "./dist/linalg/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "PERFORMANCE.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "lint": "biome check .",
    "bench": "bun run src/benchmark.ts",
    "format": "biome format --write ."
  },
  "keywords": [
    "numpy",
    "numpy-compatible",
    "python",
    "ndarray",
    "matrix",
    "linear-algebra",
    "data-science",
    "native",
    "blas",
    "wasm",
    "typescript",
    "tensor",
    "machine-learning"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SylphxAI/tsnum.git",
    "directory": "packages/numpy"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  },
  "optionalDependencies": {
    "@sylphx/numpy-native": "0.0.0"
  }
}
